{
  "schema_name": "botc_label_schema_v1",
  "version": "1.0.0",
  "purpose": [
    "Utterance-level annotation for Blood on the Clocktower and related social deduction corpora",
    "Supports data labeling, retrieval, agent prompting, behavior analysis, and training set normalization",
    "Designed to cover BOTC-specific mechanics while remaining compatible with Werewolf/Mafia/AIWolf style corpora"
  ],
  "annotation_unit": "one_utterance",
  "design_principles": [
    "Separate objective truth from speaker-believed truth",
    "Preserve BOTC-specific state such as dead-speaking, drunk, poisoned, and madness",
    "Represent both speech content and strategic function",
    "Allow multi-label speech acts",
    "Support public and private communication channels"
  ],
  "modes": {
    "mvp": {
      "description": "Minimum viable fields for quick bootstrapping",
      "required_fields": [
        "game_id",
        "script",
        "phase",
        "day_index",
        "speaker",
        "audience",
        "speaker_alive",
        "speaker_public_claim",
        "text",
        "speech_acts",
        "targets",
        "vote_stance"
      ]
    },
    "full": {
      "description": "Recommended full annotation for training and agent simulation",
      "required_fields": [
        "game_id",
        "script",
        "phase",
        "day_index",
        "utterance_id",
        "speaker",
        "audience",
        "speaker_alive",
        "speaker_private_role",
        "speaker_alignment",
        "speaker_public_claim",
        "speaker_state",
        "text",
        "speech_acts",
        "targets",
        "epistemic_strength",
        "intent",
        "truth_status_objective",
        "truth_status_subjective",
        "evidence_source",
        "vote_stance",
        "nomination_related"
      ]
    }
  },
